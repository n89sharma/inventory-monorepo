{
  "name": "inventory-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "graph": "depcruise src --include-only ^src/components --collapse ^src/components/[^/]+ --output-type dot | dot -Tsvg -o diagrams/components-highlevel.svg",
    "graph:detail": "depcruise src --include-only ^src/components --output-type dot | dot -Tsvg -o diagrams/components-detail.svg",
    "graph:tree": "sh -c 'f=\"${1##*/}\"; GRAPH_TREE_ROOT=\"$f\" depcruise \"$1\" --config .dependency-cruiser-tree.cjs --output-type dot | dot -Tsvg -o \"diagrams/${f%.*}-tree.svg\"' --"
  },
  "dependencies": {
    "@clerk/react": "^6.4.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "immer": "^11.1.4",
    "next-themes": "^0.4.6",
    "nuqs": "^2.9.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^9.13.2",
    "react-dom": "^19.2.6",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.18.1",
    "shared-types": "^1.0.0",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tailwindcss/vite": "^4.1.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "dependency-cruiser": "^18.0.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-sonarjs": "^4.1.0",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "shadcn": "^4.4.0",
    "tailwindcss": "^4.1.10",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^7.3.6",
    "vite-bundle-visualizer": "^1.2.1",
    "vitest": "^4.1.9"
  }
}
