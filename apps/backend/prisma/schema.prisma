generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["typedSql"]
}

datasource db {
  provider = "postgresql"
}

// Static values
model Accessory {
  id               Int              @id @default(autoincrement())
  accessory        String           @unique
  assetAccessories AssetAccessory[]
}

model AssetType {
  id         Int     @id @default(autoincrement())
  asset_type String  @unique
  models     Model[]
}

model Status {
  id     Int     @id @default(autoincrement())
  status String  @unique
  assets Asset[]
}

model Readiness {
  id     Int     @id @default(autoincrement())
  status String  @unique
  assets Asset[]
}

model FileType {
  id    Int    @id @default(autoincrement())
  type  String @unique
  files File[]
}

model InvoiceType {
  id       Int       @id @default(autoincrement())
  type     String    @unique
  invoices Invoice[]
}

model Country {
  id     Int     @id @default(autoincrement())
  name   String
  assets Asset[]
}

// MODELS
model Asset {
  id            Int    @id @default(autoincrement())
  barcode       String @unique @db.VarChar(50)
  serial_number String @db.VarChar(50)
  model_id      Int
  location_id   Int?

  status_id    Int
  readiness_id Int

  purchase_invoice_id     Int?
  sales_invoice_id        Int?
  arrival_id              Int?
  departure_id            Int?
  hold_id                 Int?
  cost                    Cost?
  technical_specification TechnicalSpecification?
  country_of_origin_id    Int?
  manufactured_year       Int?
  created_at              DateTime

  is_in_transit Boolean @default(false)

  barcode_normalized String? @default(dbgenerated()) @map("barcode_normalized")
  serial_normalized  String? @default(dbgenerated()) @map("serial_normalized")

  model             Model               @relation(fields: [model_id], references: [id])
  location          Location?           @relation(fields: [location_id], references: [id])
  purchase_invoice  Invoice?            @relation("PurchaseInvoice", fields: [purchase_invoice_id], references: [id])
  sales_invoice     Invoice?            @relation("SalesInvoice", fields: [sales_invoice_id], references: [id])
  arrival           Arrival?            @relation(fields: [arrival_id], references: [id])
  departure         Departure?          @relation(fields: [departure_id], references: [id])
  hold              Hold?               @relation(fields: [hold_id], references: [id])
  status            Status              @relation(fields: [status_id], references: [id])
  readiness         Readiness           @relation(fields: [readiness_id], references: [id])
  asset_accessories AssetAccessory[]
  asset_store_parts AssetStorePart[]
  asset_errors      AssetError[]
  donated_parts     AssetSalvagedPart[] @relation("DonatedParts")
  received_parts    AssetSalvagedPart[] @relation("ReceivedParts")
  asset_transfers   AssetTransfer[]
  files             File[]
  comments          Comment[]
  country_of_origin Country?            @relation(fields: [country_of_origin_id], references: [id])

  @@index([barcode_normalized(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([serial_normalized(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([serial_number])
  @@index([model_id])
  @@index([location_id])
  @@index([status_id])
  @@index([readiness_id])
  @@index([arrival_id])
  @@index([departure_id])
  @@index([hold_id])
  @@index([purchase_invoice_id])
  @@index([sales_invoice_id])
  @@index([created_at(sort: Desc)])
}

model TechnicalSpecification {
  id           Int  @id @default(autoincrement())
  asset_id     Int  @unique
  cassettes    Int?
  meter_black  Int?
  meter_colour Int?
  meter_total  Int?
  drum_life_c  Int?
  drum_life_m  Int?
  drum_life_y  Int?
  drum_life_k  Int?
  toner_life_c Int?
  toner_life_m Int?
  toner_life_y Int?
  toner_life_k Int?
  component_id Int?

  component Component? @relation(fields: [component_id], references: [id])
  asset     Asset      @relation(fields: [asset_id], references: [id])

  @@index([meter_black])
  @@index([meter_colour])
  @@index([meter_total])
  @@index([component_id])
}

model Cost {
  id              Int      @id @default(autoincrement())
  asset_id        Int      @unique
  purchase_cost   Decimal? @db.Decimal(12, 2)
  transport_cost  Decimal? @db.Decimal(12, 2)
  processing_cost Decimal? @db.Decimal(12, 2)
  other_cost      Decimal? @db.Decimal(12, 2)
  parts_cost      Decimal? @db.Decimal(12, 2)
  total_cost      Decimal? @db.Decimal(12, 2)
  sale_price      Decimal? @db.Decimal(12, 2)

  asset Asset @relation(fields: [asset_id], references: [id])

  @@index([purchase_cost])
  @@index([transport_cost])
  @@index([processing_cost])
  @@index([other_cost])
  @@index([parts_cost])
  @@index([total_cost])
  @@index([sale_price])
}

model AssetAccessory {
  asset_id     Int
  accessory_id Int

  accessory Accessory @relation(fields: [accessory_id], references: [id])
  asset     Asset     @relation(fields: [asset_id], references: [id])

  @@id([asset_id, accessory_id])
}

model Error {
  id       Int @id @default(autoincrement())
  brand_id Int

  code        String  @db.VarChar(15)
  description String?
  category    String  @db.Text

  brand        Brand        @relation(fields: [brand_id], references: [id])
  asset_errors AssetError[]

  @@unique([brand_id, code])
  @@index([code])
}

model AssetError {
  asset_id Int
  error_id Int
  is_fixed Boolean
  added_by Int?
  added_at DateTime?
  fixed_by Int?
  fixed_at DateTime?

  asset   Asset @relation(fields: [asset_id], references: [id])
  error   Error @relation(fields: [error_id], references: [id])
  addedBy User? @relation("ErrorAddedBy", fields: [added_by], references: [id])
  fixedBy User? @relation("ErrorFixedBy", fields: [fixed_by], references: [id])

  @@id([asset_id, error_id])
}

model StorePart {
  id          Int    @id @default(autoincrement())
  part_number String @unique @db.VarChar(50)
  description String @db.Text

  transactions      StoreTransaction[]
  asset_store_parts AssetStorePart[]
}

model StoreTransactionType {
  id           Int                @id @default(autoincrement())
  type         String             @unique
  is_inbound   Boolean
  transactions StoreTransaction[]
}

model StoreTransaction {
  id                       Int      @id @default(autoincrement())
  store_transaction_number String   @unique @db.VarChar(50)
  store_part_id            Int
  transaction_type_id      Int
  quantity                 Int
  unit_cost                Decimal? @db.Decimal(12, 2)
  departure_id             Int?
  warehouse_id             Int
  created_by_id            Int
  created_at               DateTime
  notes                    String?  @db.Text

  warehouse         Warehouse            @relation(fields: [warehouse_id], references: [id])
  store_part        StorePart            @relation(fields: [store_part_id], references: [id])
  transaction_type  StoreTransactionType @relation(fields: [transaction_type_id], references: [id])
  departure         Departure?           @relation(fields: [departure_id], references: [id])
  created_by        User                 @relation(fields: [created_by_id], references: [id])
  asset_store_parts AssetStorePart[]

  @@index([store_part_id, created_at(sort: Desc)])
  @@index([transaction_type_id])
  @@index([departure_id])
  @@index([created_by_id])
  @@index([created_at(sort: Desc)])
}

model AssetStorePart {
  id                   Int      @id @default(autoincrement())
  asset_id             Int
  store_part_id        Int
  store_transaction_id Int
  estimated_cost       Decimal  @db.Decimal(12, 2)
  created_by_id        Int
  created_at           DateTime

  asset             Asset            @relation(fields: [asset_id], references: [id])
  store_part        StorePart        @relation(fields: [store_part_id], references: [id])
  store_transaction StoreTransaction @relation(fields: [store_transaction_id], references: [id])
  created_by        User             @relation(fields: [created_by_id], references: [id])

  @@index([asset_id])
  @@index([store_part_id])
  @@index([store_transaction_id])
  @@index([created_by_id])
}

model AssetSalvagedPart {
  id                 Int      @id @default(autoincrement())
  recipient_asset_id Int
  donor_asset_id     Int
  fixed_at           DateTime
  fixed_by           Int
  is_exchange        Boolean
  part               String   @db.Text
  notes              String?  @db.Text

  recipient_asset Asset @relation("ReceivedParts", fields: [recipient_asset_id], references: [id])
  donor_asset     Asset @relation("DonatedParts", fields: [donor_asset_id], references: [id])
  fixedBy         User  @relation(fields: [fixed_by], references: [id])

  @@index([recipient_asset_id])
  @@index([donor_asset_id])
}

model Transfer {
  id              Int      @id @default(autoincrement())
  transfer_number String   @unique @db.VarChar(50)
  origin_id       Int
  destination_id  Int
  transporter_id  Int
  created_by_id   Int
  notes           String?
  created_at      DateTime

  origin          Warehouse       @relation("TransferOrigin", fields: [origin_id], references: [id])
  destination     Warehouse       @relation("TransferDestination", fields: [destination_id], references: [id])
  transporter     Organization    @relation(fields: [transporter_id], references: [id])
  created_by      User            @relation(fields: [created_by_id], references: [id])
  asset_transfers AssetTransfer[]

  @@index([created_at(sort: Desc)])
  @@index([origin_id, destination_id])
  @@index([destination_id])
  @@index([transporter_id])
}

model AssetTransfer {
  asset_id    Int
  transfer_id Int

  asset    Asset    @relation(fields: [asset_id], references: [id])
  transfer Transfer @relation(fields: [transfer_id], references: [id])

  @@id([asset_id, transfer_id])
}

model Arrival {
  id             Int      @id @default(autoincrement())
  arrival_number String   @unique @db.VarChar(50)
  origin_id      Int
  destination_id Int
  transporter_id Int
  created_by_id  Int
  notes          String?  @db.Text
  created_at     DateTime

  origin      Organization @relation("ArrivalOrigin", fields: [origin_id], references: [id])
  destination Warehouse    @relation(fields: [destination_id], references: [id])
  transporter Organization @relation("ArrivalTransporter", fields: [transporter_id], references: [id])
  created_by  User         @relation(fields: [created_by_id], references: [id])
  assets      Asset[]

  @@index([destination_id, created_at(sort: Desc)])
  @@index([created_at(sort: Desc)])
  @@index([origin_id])
  @@index([destination_id])
  @@index([transporter_id])
}

model Departure {
  id                      Int      @id @default(autoincrement())
  departure_number        String   @unique @db.VarChar(50)
  origin_id               Int
  destination_id          Int
  transporter_id          Int
  created_by_id           Int?
  sales_representative_id Int?
  notes                   String?
  created_at              DateTime

  origin               Warehouse          @relation(fields: [origin_id], references: [id])
  destination          Organization       @relation(fields: [destination_id], references: [id])
  transporter          Organization       @relation("DepartureTransporter", fields: [transporter_id], references: [id])
  created_by           User?              @relation(fields: [created_by_id], references: [id])
  sales_representative User?              @relation("SalesRep", fields: [sales_representative_id], references: [id])
  assets               Asset[]
  store_transactions   StoreTransaction[]

  @@index([origin_id, created_at(sort: Desc)])
  @@index([created_at(sort: Desc)])
  @@index([origin_id])
  @@index([destination_id])
  @@index([transporter_id])
}

model Hold {
  id             Int       @id @default(autoincrement())
  hold_number    String    @unique @db.VarChar(50)
  created_by_id  Int
  created_for_id Int
  customer_id    Int
  notes          String?
  created_at     DateTime
  from_dt        DateTime?
  to_dt          DateTime?
  archived_at    DateTime?

  created_by  User         @relation("HoldCreatedBy", fields: [created_by_id], references: [id])
  created_for User         @relation("HoldCreatedFor", fields: [created_for_id], references: [id])
  customer    Organization @relation(fields: [customer_id], references: [id])
  assets      Asset[]

  @@index([created_at(sort: Desc)])
  @@index([created_for_id, customer_id])
  @@index([created_by_id])
  @@index([customer_id])
  @@index([from_dt])
  @@index([to_dt])
  @@index([archived_at])
}

model Invoice {
  id                Int      @id @default(autoincrement())
  invoice_number    String   @unique @db.VarChar(50)
  invoice_reference String   @db.Text
  organization_id   Int
  updated_by_id     Int
  is_cleared        Boolean
  created_at        DateTime
  invoice_type_id   Int

  invoice_type    InvoiceType  @relation(fields: [invoice_type_id], references: [id])
  organization    Organization @relation(fields: [organization_id], references: [id])
  updated_by      User         @relation(fields: [updated_by_id], references: [id])
  purchase_assets Asset[]      @relation("PurchaseInvoice")
  sales_assets    Asset[]      @relation("SalesInvoice")

  @@index([created_at(sort: Desc)])
  @@index([invoice_type_id])
  @@index([invoice_number])
}

model Location {
  id           Int    @id @default(autoincrement())
  warehouse_id Int
  zone_id      Int
  bin          String @default("")

  warehouse Warehouse @relation(fields: [warehouse_id], references: [id])
  zone      Zone      @relation(fields: [zone_id], references: [id])
  assets    Asset[]

  @@unique([warehouse_id, zone_id, bin])
}

model Zone {
  id        Int        @id @default(autoincrement())
  zone      String     @unique
  locations Location[]
}

model Warehouse {
  id                    Int                @id @default(autoincrement())
  city_code             String             @db.Char(3)
  street                String             @db.Text
  is_active             Boolean            @default(false)
  origin_transfers      Transfer[]         @relation("TransferOrigin")
  destination_transfers Transfer[]         @relation("TransferDestination")
  departures            Departure[]
  arrivals              Arrival[]
  locations             Location[]
  users                 User[]
  storeTransactions     StoreTransaction[]

  @@unique([city_code, street])
}

model Brand {
  id         Int         @id @default(autoincrement())
  name       String      @unique @db.Text
  models     Model[]
  errors     Error[]
  components Component[]
}

model Model {
  id         Int       @id @default(autoincrement())
  name       String    @db.Text
  asset_type AssetType @relation(fields: [asset_type_id], references: [id])
  weight     Float
  size       Float
  is_colour  Boolean   @default(false)

  brand         Brand   @relation(fields: [brand_id], references: [id])
  brand_id      Int
  assets        Asset[]
  asset_type_id Int

  @@unique([brand_id, name])
  @@index([name])
}

model Component {
  id                       Int                      @id @default(autoincrement())
  name                     String
  brand_id                 Int
  brand                    Brand                    @relation(fields: [brand_id], references: [id])
  technical_specifications TechnicalSpecification[]

  @@unique([brand_id, name])
  @@index([name])
}

model File {
  id             Int      @id @default(autoincrement())
  asset_id       Int
  uploaded_by_id Int
  name           String   @db.Text
  data           Bytes
  url            String
  size           Int
  uploaded_at    DateTime
  file_type_id   Int

  type        FileType @relation(fields: [file_type_id], references: [id])
  asset       Asset    @relation(fields: [asset_id], references: [id])
  uploaded_by User     @relation(fields: [uploaded_by_id], references: [id])

  @@index([asset_id, uploaded_at(sort: Desc)])
  @@index([uploaded_by_id])
  @@index([name])
}

model Comment {
  id            Int      @id @default(autoincrement())
  asset_id      Int
  created_by_id Int
  comment       String
  created_at    DateTime
  updated_at    DateTime

  asset      Asset @relation(fields: [asset_id], references: [id])
  created_by User  @relation(fields: [created_by_id], references: [id])

  @@index([asset_id, created_at(sort: Desc)])
  @@index([created_by_id])
}

model User {
  id                   Int     @id @default(autoincrement())
  name                 String  @unique @db.Text
  email                String? @unique @db.Text
  clerk_id             String? @unique @db.Text
  is_active            Boolean @default(false)
  default_warehouse_id Int?
  role                 String?

  default_warehouse    Warehouse?          @relation(fields: [default_warehouse_id], references: [id])
  asset_errors_added   AssetError[]        @relation("ErrorAddedBy")
  asset_errors_fixed   AssetError[]        @relation("ErrorFixedBy")
  transfers            Transfer[]
  departures           Departure[]
  departure_sales_reps Departure[]         @relation("SalesRep")
  arrivals             Arrival[]
  holds_created        Hold[]              @relation("HoldCreatedBy")
  holds_for            Hold[]              @relation("HoldCreatedFor")
  invoices_updated     Invoice[]
  files                File[]
  comments             Comment[]
  history              History[]
  store_transactions   StoreTransaction[]
  salvaged_asset_parts AssetSalvagedPart[]
  store_asset_parts    AssetStorePart[]
  savedViews           SavedView[]
}

model SavedView {
  id            Int      @id @default(autoincrement())
  name          String   @db.VarChar(100)
  page_key      String   @db.VarChar(40)
  query_string  String
  column_ids    String[] @default([])
  created_by_id Int
  created_at    DateTime @default(now())
  created_by    User     @relation(fields: [created_by_id], references: [id])

  @@unique([created_by_id, page_key, name])
  @@index([created_by_id, page_key])
}

model Organization {
  id              Int     @id @default(autoincrement())
  account_number  String  @unique @db.VarChar(50)
  name            String  @db.Text
  contact_name    String? @db.Text
  phone           String? @db.Text
  phone_ext       String? @db.Text
  mobile          String? @db.Text
  primary_email   String? @db.Text
  secondary_email String? @db.Text
  address         String? @db.Text
  city            String? @db.Text
  province        String? @db.Text
  country         String? @db.Text
  website         String? @db.Text

  invoices               Invoice[]
  arrivals_origin        Arrival[]   @relation("ArrivalOrigin")
  arrivals_transporter   Arrival[]   @relation("ArrivalTransporter")
  departures_destination Departure[]
  departures_transporter Departure[] @relation("DepartureTransporter")
  holds                  Hold[]
  transfers              Transfer[]

  @@index([name])
}

model History {
  id          Int      @id @default(autoincrement())
  user_id     Int
  changed_on  DateTime
  changes     Json
  entity_type String
  entity_id   Int
  action_type String

  user User @relation(fields: [user_id], references: [id])

  @@index([entity_type, entity_id, changed_on(sort: Desc)])
  @@index([user_id, changed_on(sort: Desc)])
}
