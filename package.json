{
  "name": "inventory-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "tbuild": "npm run build -w packages/shared-types",
    "bbuild": "npm run build -w packages/shared-types && npm run build -w apps/backend",
    "fbuild": "npm run build -w apps/frontend",
    "bdev": "npm run dev -w apps/backend",
    "fdev": "npm run dev -w apps/frontend",
    "bstart": "npm run start -w apps/backend",
    "tlint": "npm run lint -w packages/shared-types",
    "blint": "npm run lint -w apps/backend",
    "flint": "npm run lint -w apps/frontend",
    "ftypecheck": "npm run typecheck -w apps/frontend",
    "verify": "npm run tlint && npm run blint && npm run flint && npm run knip && npm run bbuild && npm run ftypecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": "prettier --write"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "knip": "^6.20.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4"
  }
}
