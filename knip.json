{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "apps/backend": {
      "entry": ["test/**"],
      "ignore": ["generated/**"]
    },
    "apps/frontend": {
      "entry": ["src/components/shadcn/**", "src/**/*.d.ts"],
      "ignoreDependencies": ["shadcn", "vite-bundle-visualizer"],
      "ignoreBinaries": ["dot"],
      "ignore": [".dependency-cruiser-tree.cjs"]
    }
  }
}
